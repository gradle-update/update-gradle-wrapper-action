{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["ES2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./lib",
    "rootDir": "./src",
    "types": ["node"],
    "strict": true,
    "noImplicitReturns": true,
    "isolatedModules": true,
    "removeComments": true
  },
  "exclude": [
    "node_modules",
    "tests"
  ]
}
