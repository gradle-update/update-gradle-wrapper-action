{
  "name": "update-gradle-wrapper-action",
  "version": "0.0.0",
  "private": true,
  "description": "Update Gradle Wrapper in your project",
  "main": "lib/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf lib/ dist/",
    "format": "prettier --write '{src,tests}/**/*.ts'",
    "format-check": "prettier --check '{src,tests}/**/*.ts'",
    "lint": "eslint . --fix",
    "lint-check": "eslint .",
    "build": "tsc",
    "pack": "ncc build",
    "test": "jest",
    "all": "npm ls && npm run clean && npm run format && npm run lint && npm run build && npm run test && npm run pack"
  },
  "author": "Cristian Greco",
  "license": "Apache 2.0",
  "keywords": [
    "gradle",
    "actions"
  ],
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^6.0.1",
    "@actions/glob": "^0.5.0",
    "@actions/http-client": "^2.2.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@jest/globals": "^30.4.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.59.3",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.30.1",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "jest": "^30.4.2",
    "nock": "^14.0.15",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.2"
  }
}
